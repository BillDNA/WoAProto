{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start game server",
      "detail": "node game/server.js — the standard dev path (writes/persistence only work through this).",
      "type": "shell",
      "command": "node",
      "args": ["game/server.js"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "clear": true },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(never)(matches)(anything)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "server running"
        }
      }
    },
    {
      "label": "Run engine tests",
      "detail": "node game/test.js",
      "type": "shell",
      "command": "node",
      "args": ["game/test.js"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Run UI smoke test",
      "detail": "node dev/smoke.js",
      "type": "shell",
      "command": "node",
      "args": ["dev/smoke.js"],
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
