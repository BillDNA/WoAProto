# Obsidian workspace (local editor state)
.obsidian/

# dev harness dependencies (jsdom for dev/smoke.js) and scratch screenshots
dev/node_modules/
dev/package*.json
dev/*.png

# Windows cruft
desktop.ini
Thumbs.db

# Art source binaries stay local (public repo, big files)
# (moved under dynamic-scrum/planning/specs/original-specs/ in the round-2 doc reorg)
dynamic-scrum/planning/specs/original-specs/ProtoArt/
dynamic-scrum/planning/specs/original-specs/art-originals/
dynamic-scrum/planning/specs/original-specs/prototype pictures/*
# ...except the diagram the terrain rules are defined by
!dynamic-scrum/planning/specs/original-specs/prototype pictures/HexClarificationDiagram.png

# Playtest reports live under logs/reports/ (Feedback Round 4). The balance +
# battle .md reports ARE the corpus the report skills read, so they're tracked;
# only the append-only master log, live scratch log, and debug-state dumps are
# noise — ignored.
logs/reports/battle/claude-plays-log.jsonl
logs/reports/battle/run-live.log
logs/debug/*
!logs/debug/.gitkeep
dev/claude-plays-log.jsonl

# V1 battle database — a regenerable index over the committed reports (Bill's
# ruling: gitignore for now). WAL mode adds -wal/-shm siblings.
logs/woa.db
logs/woa.db-wal
logs/woa.db-shm

# DynamicScrum — per-machine/ephemeral (statusLine readout, local settings, hub mutation log)
.claude-status
.claude/settings.local.json
.board-log.jsonl
