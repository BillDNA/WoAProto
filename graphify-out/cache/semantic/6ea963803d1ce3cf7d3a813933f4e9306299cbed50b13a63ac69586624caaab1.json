{"nodes": [{"id": "design_docs_war_of_attrition_rule_book", "label": "War of Attrition Rule Book", "file_type": "document", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_docs_war_of_attrition_rule_book_attrition_victory", "label": "Attrition Victory", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Victory Conditions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Scored by surviving units on the board (1/2/3 vp for infantry/cavalry/artillery); reserve units count nothing; ties go to the second player. Revised June 2026 from scoring defeated enemy units so board presence decides the standstill."}, {"id": "design_docs_war_of_attrition_rule_book_hq_capture_victory", "label": "Headquarters Capture Victory", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Victory Conditions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Attacking successfully into the opponent's HQ wins; a mutual-removal tie also counts as capture."}, {"id": "design_docs_war_of_attrition_rule_book_game_victory", "label": "Game Victory (3 Map Cards)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Victory Conditions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "First to collect 3 map cards wins; battle loser goes first in the next battle."}, {"id": "design_docs_war_of_attrition_rule_book_combat_resolution", "label": "Combat Resolution", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Compare attacker power vs defender power at the battle hex: attacker greater = defender removed & attacker advances; defender greater = attacker removed; tie = both removed."}, {"id": "design_docs_war_of_attrition_rule_book_attacker_power", "label": "Attacker's Power", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_docs_war_of_attrition_rule_book_defender_power", "label": "Defender's Power", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "design_docs_war_of_attrition_rule_book_support", "label": "Support", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Adjacent allied units add support to the battle hex; trenches deny attacker support, rivers deny both sides' support."}, {"id": "design_docs_war_of_attrition_rule_book_trench", "label": "Trench", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Building Types", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Revised July 2026: covers two edges and only denies attacking support across them. Gives no defense, never blocks the attack itself, never hinders the defender; ownership irrelevant (a captured trench serves its new occupant). Previously gave +1 defense."}, {"id": "design_docs_war_of_attrition_rule_book_river", "label": "River", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Terrain Types", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "New July 2026: sits on one border, support never crosses it for either side; attacks and movement cross freely, Airdrop may land beyond, Naval Barrage cannot remove it."}, {"id": "design_docs_war_of_attrition_rule_book_mountain", "label": "Mountain Terrain", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Terrain Types", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Grey terrain in the battle hex gives +1 defense when attacked across that edge."}, {"id": "design_docs_war_of_attrition_rule_book_forest", "label": "Forest Terrain", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Terrain Types", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Green terrain gives +1 attack when the attacker's hex borders the battle hex along a forest edge."}, {"id": "design_docs_war_of_attrition_rule_book_infantry", "label": "Infantry Unit", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Unit Types", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "1 attack / 1 defense / 1 support; 1 vp. The line unit."}, {"id": "design_docs_war_of_attrition_rule_book_cavalry", "label": "Cavalry Unit", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Unit Types", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "3 attack / 0 defense / 0 support; 2 vp. The killer."}, {"id": "design_docs_war_of_attrition_rule_book_artillery", "label": "Artillery Unit", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Unit Types", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "0 attack / 0 defense / 2 support; 3 vp. The force multiplier."}, {"id": "design_docs_war_of_attrition_rule_book_headquarters", "label": "Headquarters", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Building Types", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Gives 1 support to all adjacent hexes, has no inherent defense; units can reposition or attack through it."}, {"id": "design_docs_war_of_attrition_rule_book_turn_order", "label": "Turn Order", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Turn Order", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Draw to 4, play 1, resolve, remove the played card from the game, discard the rest; a card may always resolve as a simple attack or reposition."}, {"id": "design_docs_war_of_attrition_rule_book_map_cards", "label": "Map Cards", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Game setup", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "12-card map deck defining terrain layout and HQ start positions; the battle victor takes the card."}, {"id": "design_docs_war_of_attrition_rule_book_reposition", "label": "Reposition Action", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Action Definitions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Move a unit to an adjacent empty hex or swap two adjacent units; may move/swap through a headquarters."}, {"id": "design_docs_war_of_attrition_rule_book_deploy", "label": "Deploy / Build Action", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Action Definitions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Take a unit or building from the player mat and place it on the board."}, {"id": "design_docs_war_of_attrition_rule_book_attack", "label": "Attack Action", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Action Definitions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Select a unit to attack an adjacent occupied tile; resolved via combat resolution."}, {"id": "design_docs_war_of_attrition_rule_book_deploy_infantry_start", "label": "Deploy Infantry (Starting Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Guaranteed in the opening hand; places one infantry adjacent to a controlled hex."}, {"id": "design_docs_war_of_attrition_rule_book_airdrop", "label": "Airdrop (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Places an infantry on any empty hex; never dealt into an opening hand (house rule)."}, {"id": "design_docs_war_of_attrition_rule_book_conscription", "label": "Conscription (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Places two infantry adjacent to controlled hexes in sequence."}, {"id": "design_docs_war_of_attrition_rule_book_attack_plus1", "label": "Attack +1 (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Order an attack with +1 support to the calculation."}, {"id": "design_docs_war_of_attrition_rule_book_mass_assault", "label": "Mass Assault (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Order an attack, then order another attack."}, {"id": "design_docs_war_of_attrition_rule_book_careful_maneuvers", "label": "Careful Maneuvers (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reposition a unit, then attack with -1 support."}, {"id": "design_docs_war_of_attrition_rule_book_reckless_maneuvers", "label": "Reckless Maneuvers (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Order an attack, then reposition a unit."}, {"id": "design_docs_war_of_attrition_rule_book_ordered_withdraw", "label": "Ordered Withdraw (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Order an attack; on a tie the attacker lives but does not take the hex."}, {"id": "design_docs_war_of_attrition_rule_book_naval_barrage", "label": "Naval Barrage (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Remove a trench or forest from an adjacent controlled hex, then order an attack; cannot remove a river."}, {"id": "design_docs_war_of_attrition_rule_book_forced_march", "label": "Forced March (Card)", "file_type": "concept", "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Card Actions", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Reposition up to three times in sequence."}], "edges": [{"source": "design_docs_war_of_attrition_rule_book_combat_resolution", "target": "design_docs_war_of_attrition_rule_book_attacker_power", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "weight": 1.0}, {"source": "design_docs_war_of_attrition_rule_book_combat_resolution", "target": "design_docs_war_of_attrition_rule_book_defender_power", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "weight": 1.0}, {"source": "design_docs_war_of_attrition_rule_book_attacker_power", "target": "design_docs_war_of_attrition_rule_book_support", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "weight": 1.0}, {"source": "design_docs_war_of_attrition_rule_book_attacker_power", "target": "design_docs_war_of_attrition_rule_book_trench", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "weight": 1.0}, {"source": "design_docs_war_of_attrition_rule_book_attacker_power", "target": "design_docs_war_of_attrition_rule_book_river", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "design-docs/War Of Attrition rule book.md", "source_location": "Resolving Combat", "weight": 1.0}, {"source": "design_docs_war_of_attrition_rule_book_attacker_power", "target": "design_docs_war_of_attrition_rule_book_forest", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 