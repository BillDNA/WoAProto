ntributor": null}, {"id": "game_claude_river_terrain", "label": "River terrain (support denial both ways)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "V0 terrain-crossing revision added rivers as a two-way support blocker distinct from mountains; attacks/moves/Airdrop still cross, and it is not barrageable so a river plan survives Naval Barrage."}, {"id": "game_claude_trenches", "label": "Trenches (attacker-support denial)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "V0 terrain-crossing revision replaced the old +1 defense trench with support denial: attacker support may not cross a trenched border, attack itself always crosses, defender support unaffected, ownership irrelevant to the rules."}, {"id": "game_claude_through_hq", "label": "Through-HQ move/swap/attack rule", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "game_claude_attrition_victory", "label": "Attrition victory by surviving field units (fieldScore)", "file_type": "rationale", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "June 2026 revision: attrition scores surviving units on the board (inf1/cav2/art3), reserves and raw kills no longer score \u2014 a one-kill turtle should not beat a side that dominated the board."}, {"id": "game_claude_tie_goes_to_second", "label": "Tie-goes-to-second-mover attrition rule", "file_type": "rationale", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Tie in attrition goes to whoever moved second; still decides ~26% of battles and is called out as the biggest open balance lever for Bill."}, {"id": "game_claude_concession", "label": "Concession + advisory heuristic (concedeAdvised)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Advisory-only foregone-conclusion heuristic: field-score gap beyond ~3 VP/turn AND no unit can reach the enemy HQ in remaining turns; UI hints the human, AI auto-concedes, simBattle never concedes so balance stats stay full-game."}, {"id": "game_claude_ai_personalities", "label": "Parameterized AI + data personalities (brawler/turtle)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "game_claude_anti_degeneracy_guards", "label": "Anti-degeneracy AI guards", "file_type": "rationale", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Three guards fixed degenerate AI play: -80 noopPenalty killed dead turns (Skip% 65-75%\u21920), the attrition projection killed the swap-dance stalemate (zero-kill 44%\u21923%, 2nd-player win 78%\u219256%), and anti-shuffle penalizes re-swapping the same pair."}, {"id": "game_claude_noop_penalty", "label": "No-op turn penalty + visible dead turns (Skip%)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Bill's principle: a player should always feel they can act, so dead turns must be loud and measured \u2014 pending.acted counts real actions and 0 logs a no-effect line and marks Skip%."}, {"id": "game_claude_grading_rubrics", "label": "Grading rubrics (north stars + card/map/unit/game)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "game_claude_skill_premium", "label": "Skill premium / luck-o-meter (matchup)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "game_claude_card_metrics", "label": "Card report metrics (Skip% / Simple% / 1stSight% / AvgSeen)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "game_claude_flexible_orders", "label": "Flexible orders house rule (attack/reposition fallback)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Feedback Round 1: basic reposition refused while a basic attack is possible, to encourage attacking over shuffling."}, {"id": "game_claude_layout_v2", "label": "Layout V2 (2A + topbar scoreboard)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "game_claude_campaign_journal", "label": "Campaign Journal (turn-grouped bound book)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "game_claude_combat_clarity", "label": "Combat clarity QoL (hover attack pills, strike arrows, one-click trenches)", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "game_claude_terrain_stock", "label": "Physical terrain stock + single-hex piece rule", "file_type": "concept", "source_file": "game/CLAUDE.md", "source_location": null, "source_url": nul